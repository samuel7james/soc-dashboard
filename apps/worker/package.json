{
  "name": "@soc/worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --import ./otel/instrumentation.mjs src/index.ts",
    "build": "node ../../packages/config/build-node-app.mjs",
    "start": "node --import ./otel/instrumentation.mjs dist/index.js",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.78.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.220.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.220.0",
    "@opentelemetry/resources": "^2.9.0",
    "@opentelemetry/sdk-metrics": "^2.9.0",
    "@opentelemetry/sdk-node": "^0.220.0",
    "@opentelemetry/semantic-conventions": "^1.38.0",
    "@prisma/client": "^6.1.0",
    "@prisma/instrumentation": "6.19.3",
    "@soc/connectors": "workspace:*",
    "@soc/database": "workspace:*",
    "@soc/observability": "workspace:*",
    "bullmq": "^5.34.4",
    "ioredis": "5.10.1",
    "pino": "^10.3.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@soc/config": "workspace:*",
    "@types/node": "^20.19.43",
    "@vitest/coverage-v8": "^3.2.6",
    "eslint": "^9.17.0",
    "globals": "^15.13.0",
    "pino-pretty": "^13.0.0",
    "rimraf": "^6.0.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.0",
    "vitest": "^3.2.6"
  }
}
