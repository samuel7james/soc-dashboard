NODE_ENV=development
LOG_LEVEL=info

# Required — same Postgres/Redis as apps/api, see docker-compose.yml
DATABASE_URL=postgresql://soc:soc_dev_password@localhost:5432/soc_platform?schema=public
REDIS_URL=redis://localhost:6379

# Syslog UDP listener
SYSLOG_UDP_PORT=5514
SYSLOG_UDP_HOST=0.0.0.0

# How often the Demo Mode supervisor polls the demo_generator IngestionSource's isActive flag
DEMO_MODE_POLL_INTERVAL_MS=5000
