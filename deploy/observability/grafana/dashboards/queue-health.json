{
  "title": "Queue Depth & Failures",
  "uid": "soc-queue-health",
  "tags": ["soc-platform"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Queue depth (waiting + active + delayed)",
      "type": "timeseries",
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "drawStyle": "line", "fillOpacity": 10 } },
        "overrides": []
      },
      "targets": [{ "refId": "A", "expr": "soc_queue_depth", "legendFormat": "{{queue}}" }]
    },
    {
      "id": 2,
      "title": "Job failure rate by queue",
      "type": "timeseries",
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 9 },
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "drawStyle": "line", "fillOpacity": 10 } },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(soc_queue_job_failures_total[5m])) by (queue)",
          "legendFormat": "{{queue}}"
        }
      ]
    },
    {
      "id": 3,
      "title": "Total job failures (last 1h)",
      "type": "stat",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 18 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [{ "refId": "A", "expr": "sum(increase(soc_queue_job_failures_total[1h]))" }]
    }
  ]
}
